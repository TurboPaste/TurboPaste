# Normalize all text files to LF on checkout (overrides core.autocrlf).
# Keeps the working tree consistent across Windows, macOS, and Linux so
# Biome's `lineEnding: "lf"` setting matches what's on disk everywhere.
* text=auto eol=lf

# Common binary types, never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
