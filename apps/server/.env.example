# At least 32 random characters. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-me-with-32+-random-chars

# Public origin of THIS server. Must match BETTER_AUTH_URL used by the web client.
BETTER_AUTH_URL=http://localhost:3000

# Public origin of the web app, used for CORS and cookie SameSite checks.
CORS_ORIGIN=http://localhost:3001

# Postgres connection string. The bundled docker-compose ships with:
# user=postgres, password=password, db=turbopaste
DATABASE_URL=postgresql://postgres:password@localhost:5432/turbopaste

NODE_ENV=development

# Optional. When set:
#   - the public API rate limiter uses Redis instead of the in-process
#     counter (falls back to in-memory if Redis is unreachable)
#   - Better Auth uses Redis as secondary storage for sessions and its own
#     rate limiter (sessions are mirrored to Postgres for durability, but
#     reads go through Redis, if Redis is down, users cannot authenticate)
# Recommended when running behind a load balancer with multiple server replicas.
REDIS_URL=redis://localhost:6379
